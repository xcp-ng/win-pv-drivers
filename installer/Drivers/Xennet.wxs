<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <?define XenDriver="Xennet" ?>
    <?define XenDriverDependsOn="Xenvif" ?>
    <?include ../Driver.wxi ?>

    <ComponentGroup Id="$(XenDriver)Component" Directory="$(XenDriver)Dir" Source="!(bindpath.output)$(XenDriver)/$(Platform)">
      <File Name="xennet.cat" DefaultVersion="$(XennetVersion)" DefaultLanguage="1033" />
      <File Name="xennet.inf" Id="Xennet.inf" DefaultVersion="$(XennetVersion)" DefaultLanguage="1033" />
      <File Name="xennet.sys" />
    </ComponentGroup>
  </Fragment>
</Wix>
