<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <?define XenDriver="Xenhid" ?>
    <?define XenDriverDependsOn="Xenvkbd" ?>
    <?include ../Driver.wxi ?>

    <ComponentGroup Id="$(XenDriver)Component" Directory="$(XenDriver)Dir" Source="!(bindpath.output)$(XenDriver)/$(Platform)/$(Configuration)">
      <File Name="xenhid.cat" DefaultVersion="$(XenhidVersion)" DefaultLanguage="1033" />
      <File Name="xenhid.inf" Id="Xenhid.inf" DefaultVersion="$(XenhidVersion)" DefaultLanguage="1033" />
      <File Name="xenhid.sys" />
    </ComponentGroup>

    <SetProperty Id="$(XenDriver)ServiceDelete" Value="Services=xenhid" After="CostFinalize" Sequence="execute" />
  </Fragment>
</Wix>
