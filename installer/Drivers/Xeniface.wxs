<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Fragment>
    <?define XenDriver="Xeniface" ?>
    <?define XenDriverDependsOn="Xenbus" ?>
    <?include ../Driver.wxi ?>

    <ComponentGroup Id="$(XenDriver)Component" Directory="$(XenDriver)Dir" Source="!(bindpath.output)$(XenDriver)">
      <File Name="xenagent.dll" />
      <File Name="xenagent.exe" />
      <File Name="xencontrol.dll" />
      <File Name="xencontrol.lib" DefaultVersion="$(XenifaceVersion)" DefaultLanguage="1033" />
      <File Name="xeniface.cat" DefaultVersion="$(XenifaceVersion)" DefaultLanguage="1033" />
      <File Name="xeniface.inf" Id="Xeniface.inf" DefaultVersion="$(XenifaceVersion)"
          DefaultLanguage="1033" />
      <File Name="xeniface.sys" />

      <Component>
        <!--
          xenagent's time sync causes a very annoying drift, so don't do that periodically.
          TimeSyncMode=0 still does the post-resume sync, which is the only critical one.
        -->
        <RegistryValue Root="HKLM" Key="SYSTEM\CurrentControlSet\Services\xenagent" Name="TimeSyncMode" Type="integer" Value="0" />
      </Component>
    </ComponentGroup>

    <SetProperty Id="$(XenDriver)ServiceDelete" Value="Services=xenagent,xeniface" After="CostFinalize" Sequence="execute" />
  </Fragment>
</Wix>
